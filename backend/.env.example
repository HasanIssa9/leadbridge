# Database
DATABASE_URL=postgresql://user:password@localhost:5432/leadbridge
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-to-a-very-long-random-secret-64-chars-minimum
JWT_REFRESH_SECRET=change-this-refresh-secret-also-very-long-and-random

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# WhatsApp Business
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_TOKEN=your_permanent_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_string

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRO_MONTHLY_ID=price_xxx
STRIPE_PRO_YEARLY_ID=price_xxx
STRIPE_ENT_MONTHLY_ID=price_xxx
STRIPE_ENT_YEARLY_ID=price_xxx

# App
APP_URL=http://localhost:3001
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8080
SUPPORT_PHONE=+9647700000000

# Sentry (optional)
SENTRY_DSN=https://xxx@sentry.io/xxx

{
  "name": "leadbridge-backend",
  "version": "1.0.0",
  "description": "LeadBridge Iraq SaaS Backend",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "start:prod": "npm run build && npm run db:migrate && node dist/app.js",
    "db:migrate": "tsx src/scripts/migrate.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "redis": "^4.6.13",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "bullmq": "^5.7.0",
    "zod": "^3.23.4",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.4.5",
    "morgan": "^1.10.0",
    "express-rate-limit": "^7.3.1",
    "axios": "^1.7.2",
    "stripe": "^15.7.0",
    "firebase-admin": "^12.2.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.11.0",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/cors": "^2.8.17",
